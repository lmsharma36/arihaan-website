# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/arihaan-ppe

# या MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/arihaan-ppe

# JWT Secret (Strong password use करें)
JWT_SECRET=arihaan-secret-key-2026-change-this-in-production

# Email Configuration (Optional - Contact form के लिए)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# AI Draft Generator
AI_PROVIDER=openai

# OpenAI Configuration (for AI-powered product data extraction)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5
AI_REQUIRE_SUCCESS=true
AI_RETRY_ATTEMPTS=3

# HTTP server timeouts for long AI extraction requests
HTTP_REQUEST_TIMEOUT_MS=3600000
HTTP_HEADERS_TIMEOUT_MS=3610000
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000

# Media storage (Cloudflare R2)
# local: store uploads in server/public/uploads
# r2: upload directly to Cloudflare R2 and return CDN URLs
ASSET_STORAGE_PROVIDER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional if R2_ACCOUNT_ID is set:
R2_ENDPOINT=
R2_PUBLIC_BASE_URL=
R2_KEY_PREFIX=uploads
