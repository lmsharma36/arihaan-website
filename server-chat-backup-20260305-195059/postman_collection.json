  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["health"]
        },
        "description": "Check if the backend server is running"
      },
      "response": []
    },
    {
      "name": "Send Chat Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"What PPE products do you offer?\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/chat",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "chat"]
        },
        "description": "Send a single message to the AI assistant"
      },
      "response": []
    },
    {
      "name": "Chat with Context",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"conversationHistory\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Tell me about safety helmets\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"We offer various types of safety helmets from brands like 3M, Honeywell, and MSA.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"What about 3M helmets specifically?\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/chat/conversation",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "chat", "conversation"]
        },
        "description": "Send a conversation with context for more accurate responses"
      },
      "response": []
    },
